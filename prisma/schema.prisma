generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum ChecklistStatus {
  PENDING
  FINALIZED
}

// Permanent aggregate state of a ChecklistItem after visit finalization
enum ChecklistItemStatus {
  PENDING
  OK
  NOK
}

enum VisitStatus {
  NOT_STARTED
  ONGOING
  FINALIZED
}

enum VisitType {
  INITIAL
  REINSPECTION
}

// Inspector's in-field evaluation for a VisitItem; null = not yet evaluated
enum EvaluationStatus {
  OK
  NOK
}

enum CompanyStatus {
  PENDING
  ACTIVE
  SUSPENDED
}

enum SnapshotType {
  COMPANY_DAILY
  PLATFORM_DAILY
}

model Company {
  id               Int             @id @default(autoincrement())
  name             String          @db.VarChar(255)
  slug             String          @unique @db.VarChar(100)
  status           CompanyStatus   @default(PENDING)
  createdAt        DateTime        @default(now()) @map("created_at") @db.Timestamptz
  updatedAt        DateTime        @default(now()) @updatedAt @map("updated_at") @db.Timestamptz
  users            User[]
  roles            Role[]
  buildings        Building[]
  apartmentTypes   ApartmentType[]
  services         Service[]
  apartments       Apartment[]
  checklists       Checklist[]
  visits           Visit[]
  nonConformities  NonConformity[]
  photos           Photo[]
  metricsSnapshots MetricsSnapshot[]

  @@map("Company")
}

model User {
  id                  Int         @id @default(autoincrement())
  name                String      @db.VarChar(255)
  email               String      @unique @db.VarChar(255)
  passwordHash        String      @map("password_hash") @db.VarChar(255)
  roleId              Int?        @map("role_id")
  companyId           Int?        @map("company_id")
  isPlatformAdmin     Boolean     @default(false) @map("is_platform_admin")
  mustChangePassword  Boolean     @default(false) @map("must_change_password")
  role                Role?       @relation(fields: [roleId], references: [id])
  company             Company?    @relation(fields: [companyId], references: [id])
  checklistsFinalized      Checklist[]      @relation("ChecklistFinalizedBy")
  visitsAsInspector        Visit[]          @relation("VisitInspector")
  visitsCreated            Visit[]          @relation("VisitCreatedBy")
  resolvedNonConformities  NonConformity[]  @relation("NCResolvedBy")
  passwordResetToken       PasswordResetToken?
  pushTokens               PushToken[]
  createdAt           DateTime    @default(now()) @map("created_at") @db.Timestamptz
  updatedAt           DateTime    @default(now()) @updatedAt @map("updated_at") @db.Timestamptz

  @@index([companyId])
  @@map("User")
}

model PasswordResetToken {
  id        Int      @id @default(autoincrement())
  userId    Int      @unique @map("user_id")
  tokenHash String   @unique @map("token_hash") @db.VarChar(255)
  expiresAt DateTime @map("expires_at") @db.Timestamptz
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("PasswordResetToken")
}

model Role {
  id             Int          @id @default(autoincrement())
  name           String       @db.VarChar(255)
  description    String?      @db.VarChar(500)
  isSystem       Boolean      @default(false) @map("is_system")
  isCompanyAdmin Boolean      @default(false) @map("is_company_admin")
  companyId      Int?         @map("company_id")
  company        Company?     @relation(fields: [companyId], references: [id])
  permissions    Permission[] @relation("RolePermissions")
  users          User[]
  createdAt      DateTime     @default(now()) @map("created_at") @db.Timestamptz
  updatedAt      DateTime     @default(now()) @updatedAt @map("updated_at") @db.Timestamptz

  @@unique([companyId, name])
  @@index([companyId])
  @@map("Role")
}

model Permission {
  id        Int      @id @default(autoincrement())
  action    String   @unique @db.VarChar(100)
  resource  String   @db.VarChar(50)
  operation String   @db.VarChar(50)
  roles     Role[]   @relation("RolePermissions")
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz

  @@unique([resource, operation])
  @@map("Permission")
}

model Building {
  id         Int           @id @default(autoincrement())
  name       String        @db.VarChar(255)
  address    String        @db.VarChar(500)
  latitude   Float?
  longitude  Float?
  companyId  Int           @map("company_id")
  company    Company       @relation(fields: [companyId], references: [id])
  createdAt  DateTime      @default(now()) @map("created_at") @db.Timestamptz
  updatedAt  DateTime      @default(now()) @updatedAt @map("updated_at") @db.Timestamptz
  apartments Apartment[]

  @@index([companyId])
  @@map("Building")
}

model ApartmentType {
  id          Int         @id @default(autoincrement())
  name        String        @db.VarChar(255)
  description String?       @db.VarChar(500)
  companyId   Int?          @map("company_id")
  company     Company?      @relation(fields: [companyId], references: [id])
  createdAt   DateTime      @default(now()) @map("created_at") @db.Timestamptz
  updatedAt   DateTime      @default(now()) @updatedAt @map("updated_at") @db.Timestamptz
  rooms       Room[]
  apartments  Apartment[]

  @@unique([companyId, name])
  @@index([companyId])
  @@map("ApartmentType")
}

model Room {
  id              Int                  @id @default(autoincrement())
  apartmentTypeId Int                  @map("apartment_type_id")
  name            String               @db.VarChar(255)
  createdAt       DateTime             @default(now()) @map("created_at") @db.Timestamptz
  updatedAt       DateTime             @default(now()) @updatedAt @map("updated_at") @db.Timestamptz
  apartmentType   ApartmentType        @relation(fields: [apartmentTypeId], references: [id])
  apartmentRooms  ApartmentRoom[]
  defaultServices RoomDefaultService[]

  @@unique([apartmentTypeId, name])
  @@index([apartmentTypeId])
  @@map("Room")
}

model Apartment {
  id              Int             @id @default(autoincrement())
  buildingId      Int             @map("building_id")
  apartmentTypeId Int             @map("apartment_type_id")
  identifier      String          @db.VarChar(50)
  floor           Int?
  block           String?         @db.VarChar(50)
  companyId       Int             @map("company_id")
  company         Company         @relation(fields: [companyId], references: [id])
  createdAt       DateTime        @default(now()) @map("created_at") @db.Timestamptz
  updatedAt       DateTime        @default(now()) @updatedAt @map("updated_at") @db.Timestamptz
  building        Building        @relation(fields: [buildingId], references: [id])
  apartmentType   ApartmentType   @relation(fields: [apartmentTypeId], references: [id])
  rooms           ApartmentRoom[]
  checklist       Checklist?

  @@unique([buildingId, identifier])
  @@index([apartmentTypeId])
  @@index([companyId])
  @@map("Apartment")
}

model ApartmentRoom {
  id            Int                    @id @default(autoincrement())
  apartmentId   Int                    @map("apartment_id")
  roomId        Int?                   @map("room_id")
  name          String                 @db.VarChar(255)
  createdAt     DateTime               @default(now()) @map("created_at") @db.Timestamptz
  updatedAt     DateTime               @default(now()) @updatedAt @map("updated_at") @db.Timestamptz
  apartment     Apartment              @relation(fields: [apartmentId], references: [id], onDelete: Cascade)
  room          Room?                  @relation(fields: [roomId], references: [id], onDelete: SetNull)
  services      ApartmentRoomService[]

  @@index([apartmentId])
  @@index([roomId])
  @@map("ApartmentRoom")
}

model ApartmentRoomService {
  id              Int             @id @default(autoincrement())
  apartmentRoomId Int             @map("apartment_room_id")
  serviceId       Int             @map("service_id")
  createdAt       DateTime        @default(now()) @map("created_at") @db.Timestamptz
  apartmentRoom   ApartmentRoom   @relation(fields: [apartmentRoomId], references: [id], onDelete: Cascade)
  service         Service         @relation(fields: [serviceId], references: [id])
  checklistItems  ChecklistItem[]

  @@unique([apartmentRoomId, serviceId])
  @@index([serviceId])
  @@map("ApartmentRoomService")
}

model Service {
  id                    Int                    @id @default(autoincrement())
  name                  String                 @db.VarChar(255)
  description           String?                @db.VarChar(500)
  category              String?                @db.VarChar(100)
  companyId             Int?                   @map("company_id")
  company               Company?               @relation(fields: [companyId], references: [id])
  createdAt             DateTime               @default(now()) @map("created_at") @db.Timestamptz
  updatedAt             DateTime               @default(now()) @updatedAt @map("updated_at") @db.Timestamptz
  apartmentRoomServices ApartmentRoomService[]
  roomDefaultServices   RoomDefaultService[]

  @@unique([companyId, name])
  @@index([companyId])
  @@map("Service")
}

model RoomDefaultService {
  roomId    Int     @map("room_id")
  serviceId Int     @map("service_id")
  room      Room    @relation(fields: [roomId], references: [id], onDelete: Cascade)
  service   Service @relation(fields: [serviceId], references: [id], onDelete: Restrict)

  @@id([roomId, serviceId])
  @@index([serviceId])
  @@map("RoomDefaultService")
}

model Checklist {
  id            Int             @id @default(autoincrement())
  apartmentId   Int             @unique @map("apartment_id")
  title         String?         @db.VarChar(255)
  status        ChecklistStatus @default(PENDING)
  finalizedById Int?            @map("finalized_by_id")
  finalizedAt   DateTime?       @map("finalized_at") @db.Timestamptz
  companyId     Int             @map("company_id")
  company       Company         @relation(fields: [companyId], references: [id])
  createdAt     DateTime        @default(now()) @map("created_at") @db.Timestamptz
  updatedAt     DateTime        @default(now()) @updatedAt @map("updated_at") @db.Timestamptz
  apartment     Apartment       @relation(fields: [apartmentId], references: [id], onDelete: Restrict)
  finalizedBy   User?           @relation("ChecklistFinalizedBy", fields: [finalizedById], references: [id])
  items         ChecklistItem[]
  visits        Visit[]

  @@index([companyId])
  @@index([finalizedById])
  @@map("Inspection")
}

model ChecklistItem {
  id                     Int                  @id @default(autoincrement())
  checklistId            Int                  @map("checklist_id")
  apartmentRoomServiceId Int                  @map("apartment_room_service_id")
  status                 ChecklistItemStatus  @default(PENDING)
  createdAt              DateTime             @default(now()) @map("created_at") @db.Timestamptz
  updatedAt              DateTime             @default(now()) @updatedAt @map("updated_at") @db.Timestamptz
  checklist              Checklist            @relation(fields: [checklistId], references: [id], onDelete: Restrict)
  apartmentRoomService   ApartmentRoomService @relation(fields: [apartmentRoomServiceId], references: [id], onDelete: Restrict)
  visitItems             VisitItem[]

  @@unique([checklistId, apartmentRoomServiceId])
  @@index([checklistId])
  @@map("ChecklistItem")
}

model Visit {
  id            Int         @id @default(autoincrement())
  checklistId   Int         @map("checklist_id")
  inspectorId   Int?        @map("inspector_id")
  createdById   Int         @map("created_by_id")
  observations  String?     @db.Text
  status        VisitStatus @default(NOT_STARTED)
  type          VisitType   @default(INITIAL)
  parentVisitId Int?        @map("parent_visit_id")
  scheduledFor  DateTime?   @map("scheduled_for") @db.Timestamptz
  signatureUrl  String?     @map("signature_url") @db.VarChar(500)
  finalizedAt   DateTime?   @map("finalized_at") @db.Timestamptz
  companyId     Int         @map("company_id")
  company       Company     @relation(fields: [companyId], references: [id])
  createdAt     DateTime    @default(now()) @map("created_at") @db.Timestamptz
  updatedAt     DateTime    @default(now()) @updatedAt @map("updated_at") @db.Timestamptz
  checklist     Checklist   @relation(fields: [checklistId], references: [id], onDelete: Restrict)
  inspector     User?       @relation("VisitInspector", fields: [inspectorId], references: [id])
  createdBy     User        @relation("VisitCreatedBy", fields: [createdById], references: [id])
  parentVisit   Visit?      @relation("ReinspectionOf", fields: [parentVisitId], references: [id])
  reinspections Visit[]     @relation("ReinspectionOf")
  items         VisitItem[]

  @@index([checklistId])
  @@index([inspectorId])
  @@index([companyId])
  @@index([parentVisitId])
  @@map("Visit")
}

model VisitItem {
  id              Int               @id @default(autoincrement())
  visitId         Int               @map("visit_id")
  checklistItemId Int               @map("checklist_item_id")
  status          EvaluationStatus?
  createdAt       DateTime          @default(now()) @map("created_at") @db.Timestamptz
  updatedAt       DateTime          @default(now()) @updatedAt @map("updated_at") @db.Timestamptz
  visit           Visit             @relation(fields: [visitId], references: [id], onDelete: Cascade)
  checklistItem   ChecklistItem     @relation(fields: [checklistItemId], references: [id], onDelete: Restrict)
  nonConformity   NonConformity?

  @@unique([visitId, checklistItemId])
  @@index([checklistItemId])
  @@map("VisitItem")
}

model NonConformity {
  id           Int       @id @default(autoincrement())
  visitItemId  Int       @unique @map("visit_item_id")
  description  String    @db.Text
  resolvedAt   DateTime? @map("resolved_at") @db.Timestamptz
  resolvedById Int?      @map("resolved_by_id")
  createdAt    DateTime  @default(now()) @map("created_at") @db.Timestamptz
  updatedAt    DateTime  @default(now()) @updatedAt @map("updated_at") @db.Timestamptz
  companyId    Int       @map("company_id")
  company      Company   @relation(fields: [companyId], references: [id])
  visitItem    VisitItem @relation(fields: [visitItemId], references: [id], onDelete: Cascade)
  resolvedBy   User?     @relation("NCResolvedBy", fields: [resolvedById], references: [id])
  photos       Photo[]

  @@index([companyId])
  @@index([resolvedById])
  @@map("NonConformity")
}

model Photo {
  id              Int           @id @default(autoincrement())
  nonConformityId Int           @map("non_conformity_id")
  url             String        @db.VarChar(500)
  publicId        String        @map("public_id") @db.VarChar(255)
  uploadedAt      DateTime      @default(now()) @map("uploaded_at") @db.Timestamptz
  companyId       Int           @map("company_id")
  company         Company       @relation(fields: [companyId], references: [id])
  nonConformity   NonConformity @relation(fields: [nonConformityId], references: [id], onDelete: Cascade)

  @@index([nonConformityId])
  @@index([companyId])
  @@map("Photo")
}

model PushToken {
  id        Int      @id @default(autoincrement())
  userId    Int      @map("user_id")
  token     String   @unique @db.VarChar(500)
  platform  String   @db.VarChar(10)
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("PushToken")
}

model AuditLog {
  id         Int      @id @default(autoincrement())
  companyId  Int?     @map("company_id")
  userId     Int      @map("user_id")
  entityType String   @map("entity_type") @db.VarChar(50)
  entityId   Int      @map("entity_id")
  action     String   @db.VarChar(50)
  before     Json?    @map("before_json")
  after      Json?    @map("after_json")
  ip         String?  @db.VarChar(45)
  createdAt  DateTime @default(now()) @map("created_at") @db.Timestamptz

  @@index([companyId, entityType, entityId])
  @@index([userId])
  @@map("AuditLog")
}

model MetricsSnapshot {
  id           Int          @id @default(autoincrement())
  companyId    Int?         @map("company_id")
  snapshotDate DateTime     @map("snapshot_date") @db.Date
  type         SnapshotType
  data         Json
  createdAt    DateTime     @default(now()) @map("created_at") @db.Timestamptz
  company      Company?     @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@unique([companyId, snapshotDate, type])
  @@index([companyId, snapshotDate])
  @@map("MetricsSnapshot")
}
