generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id        Int       @id @default(autoincrement())
  name      String    @db.VarChar(255)
  email     String    @unique @db.VarChar(255)
  passwordHash String    @map("password_hash") @db.VarChar(255)
  roleId    Int       @map("role_id")
  role      Role      @relation(fields: [roleId], references: [id])
  createdAt DateTime? @default(now()) @map("created_at") @db.Timestamptz
  updatedAt DateTime? @default(now()) @updatedAt @map("updated_at") @db.Timestamptz

  inspectChecklists Checklist[] @relation("InspectBy")
  signedChecklists  Checklist[] @relation("SignedBy")

  @@map("User")
}

model Role {
  id            Int          @id @default(autoincrement())
  name          String       @unique @db.VarChar(255)
  permissionsId Int?         @map("permissions")
  permission    Permissions? @relation(fields: [permissionsId], references: [id])
  users         User[]

  @@map("Role")
}

model Permissions {
  id     Int    @id @default(autoincrement())
  action String @unique @db.VarChar(255)
  roles  Role[]

  @@map("Permissions")
}

model Building {
  id         Int         @id @default(autoincrement())
  name       String      @db.VarChar(255)
  address    String      @db.VarChar(255)
  apartments Apartment[]
  checklists Checklist[]
  createdAt  DateTime?   @default(now()) @map("created_at") @db.Timestamptz
  updatedAt  DateTime?   @default(now()) @updatedAt @map("updated_at") @db.Timestamptz

  @@map("Building")
}

model Apartment {
  id           Int          @id @default(autoincrement())
  buildingId   Int          @map("building_id")
  building     Building     @relation(fields: [buildingId], references: [id])
  dependencies Dependency[]
  checklists   Checklist[]
  createdAt    DateTime?    @default(now()) @map("created_at") @db.Timestamptz
  updatedAt    DateTime?    @default(now()) @updatedAt @map("updated_at") @db.Timestamptz

  @@map("Apartment")
}

model Dependency {
  id          Int         @id @default(autoincrement())
  name        String      @db.VarChar(255)
  quantity    Int?
  apartmentId Int         @map("apartment_id")
  apartment   Apartment   @relation(fields: [apartmentId], references: [id])
  checklists  Checklist[]
  createdAt   DateTime?   @default(now()) @map("created_at") @db.Timestamptz
  updatedAt   DateTime?   @default(now()) @updatedAt @map("updated_at") @db.Timestamptz

  @@map("Dependency")
}

model Inspection {
  id           Int         @id @default(autoincrement())
  name         String      @db.VarChar(255)
  approved     Boolean?    @default(false)
  observations String?     @db.Text
  services     Service[]
  checklists   Checklist[]
  createdAt    DateTime?   @default(now()) @map("created_at") @db.Timestamptz
  updatedAt    DateTime?   @default(now()) @updatedAt @map("updated_at") @db.Timestamptz

  @@map("Inspection")
}

model Service {
  id           Int         @id @default(autoincrement())
  name         String      @db.VarChar(255)
  type         String?     @db.VarChar(255)
  inspectionId Int?        @map("inspection_id")
  inspection   Inspection? @relation(fields: [inspectionId], references: [id])
  checklists   Checklist[]
  createdAt    DateTime?   @default(now()) @map("created_at") @db.Timestamptz
  updatedAt    DateTime?   @default(now()) @updatedAt @map("updated_at") @db.Timestamptz

  @@map("Service")
}

model Checklist {
  id             Int        @id @default(autoincrement())
  buildingId     Int        @map("building_id")
  building       Building   @relation(fields: [buildingId], references: [id])
  apartmentId    Int        @map("apartment_id")
  apartment      Apartment  @relation(fields: [apartmentId], references: [id])
  dependencyId   Int        @map("dependency_id")
  dependency     Dependency @relation(fields: [dependencyId], references: [id])
  serviceId      Int?       @map("service_id")
  service        Service?   @relation(fields: [serviceId], references: [id])
  inspectionId   Int        @map("inspection_id")
  inspection     Inspection @relation(fields: [inspectionId], references: [id])
  inspectById    Int        @map("inspect_by")
  inspectBy      User       @relation("InspectBy", fields: [inspectById], references: [id])
  signedById     Int        @map("signed_by")
  signedBy       User       @relation("SignedBy", fields: [signedById], references: [id])
  dateInspection DateTime   @map("date_inspection") @db.Timestamptz
  createdAt      DateTime?  @default(now()) @map("created_at") @db.Timestamptz
  updatedAt      DateTime?  @default(now()) @updatedAt @map("updated_at") @db.Timestamptz

  @@map("Checklist")
}
