{
  "name": "project-construction-back",
  "version": "1.0.0",
  "description": "",
  "scripts": {
    "dev": "tsx watch src/main/server.ts",
    "build": "tsc",
    "vercel-build": "prisma generate && prisma migrate deploy && tsc",
    "start": "node dist/src/main/server.js",
    "postinstall": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:deploy": "prisma migrate deploy",
    "db:studio": "prisma studio",
    "db:push:dev": "prisma db push",
    "db:seed": "tsx prisma/seed.ts",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write \"src/**/*.ts\" \"api/**/*.ts\"",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "engines": {
    "node": ">=22"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/AKI-Softwares/project-construction-back.git"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "module",
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
  "bugs": {
    "url": "https://github.com/AKI-Softwares/project-construction-back/issues"
  },
  "homepage": "https://github.com/AKI-Softwares/project-construction-back#readme",
  "dependencies": {
    "@fastify/cors": "^11.2.0",
    "@fastify/jwt": "^10.0.0",
    "@fastify/multipart": "^10.0.0",
    "@fastify/rate-limit": "^11.0.0",
    "@neondatabase/serverless": "^0.10.4",
    "@prisma/adapter-neon": "^7.7.0",
    "@prisma/client": "^7.7.0",
    "bcrypt": "^6.0.0",
    "cloudinary": "^2.10.0",
    "dotenv": "^16.5.0",
    "fastify": "^5.8.5",
    "fastify-type-provider-zod": "^6.1.0",
    "file-type": "^22.0.1",
    "resend": "^6.12.4",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "@types/bcrypt": "^6.0.0",
    "@types/node": "^25.6.0",
    "@types/ws": "^8.18.1",
    "@typescript-eslint/eslint-plugin": "^8.59.0",
    "@typescript-eslint/parser": "^8.59.0",
    "@vitest/coverage-v8": "^4.1.8",
    "eslint": "^10.2.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "pino-pretty": "^13.1.3",
    "prettier": "^3.8.3",
    "prisma": "^7.7.0",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.8",
    "ws": "^8.21.0"
  }
}
